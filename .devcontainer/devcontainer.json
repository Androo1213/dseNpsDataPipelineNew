{
    "name": "DSE Cal-Adapt Pipeline",
    "build": {
        "dockerfile": "../Dockerfile"
    },
    "overrideCommand": true,
    "remoteEnv": {
        "PATH": "/opt/conda/envs/py-env/bin:/opt/conda/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
        "PYTHONPATH": "${containerWorkspaceFolder}/lib"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/opt/conda/envs/py-env/bin/python",
                "python.condaPath": "/opt/conda/bin/conda"
            }
        }
    },
    "postCreateCommand": "/opt/conda/envs/py-env/bin/python -m ipykernel install --user --name py-env --display-name 'Python (py-env)'"
}
